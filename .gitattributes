# Normalize line endings to LF in the repository
* text=auto eol=lf

# Force LF for source files
*.cs    text eol=lf
*.csproj text eol=lf
*.slnx  text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.config text eol=lf
*.editorconfig text eol=lf
*.gitignore text eol=lf

# Binaries — no conversion
*.png   binary
*.jpg   binary
*.ico   binary
*.dll   binary
*.exe   binary
